APP_NAME=Dynamic-RAG
ENVIRONMENT=development
DEBUG=True

HOST=127.0.0.1
PORT=8000

LOG_LEVEL=INFO

# ==========================
# Database
# ==========================

MONGO_URI=mongodb://localhost:27017

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ==========================
# LLM Configuration
# ==========================

LLM_PROVIDER=groq

GROQ_API_KEY=your_groq_api_key_here

DEFAULT_LLM=llama-3.3-70b-versatile
FAST_MODEL=llama-3.1-8b-instant
CRITIC_MODEL=deepseek-r1-distill-llama-70b

TEMPERATURE=0.2
MAX_TOKENS=2048

# ==========================
# Retrieval
# ==========================

TOP_K=5
RERANK_TOP_K=10

CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ==========================
# Runtime
# ==========================

REQUEST_TIMEOUT=30
MAX_RETRIES=2